{
  "name": "simnode",
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "simnode": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@simnode/clock": "0.1.0",
    "@simnode/filesystem": "0.1.0",
    "@simnode/http-proxy": "0.1.0",
    "@simnode/mongo": "0.1.0",
    "@simnode/pg-mock": "0.1.0",
    "@simnode/random": "0.1.0",
    "@simnode/redis-mock": "0.1.0",
    "@simnode/scheduler": "0.1.0",
    "@simnode/tcp": "0.1.0",
    "mongodb-memory-server": "^10.0.0"
  }
}
